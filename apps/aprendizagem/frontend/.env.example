# API Configuration
# BACKEND_URL: usado server-side pelo BFF proxy (app/api/backend/[...path]/route.ts).
# Deve apontar para a base do FastAPI sem o sufixo /v1 (ex.: https://api.aprendizagem.app).
# Em desenvolvimento local: http://localhost:8000
BACKEND_URL=http://localhost:8000

# NEXT_PUBLIC_API_BASE_URL: legado, ainda lido por lib/config.ts como fallback
# para o BFF derivar a base. Pode ser removido se BACKEND_URL estiver setado.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/v1
NEXT_PUBLIC_APP_URL=https://aprendizagem.app

# Supabase Configuration (for parent auth redirects)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Development Configuration
NEXT_PUBLIC_USE_MOCKS=false
NEXT_PUBLIC_DEBUG=false

# Analytics & Monitoring
SENTRY_DSN=https://...@sentry.io/123

# Environment
NODE_ENV=development