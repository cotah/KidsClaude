# Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# JWT para crianças
CHILD_JWT_SECRET=your-random-256bit-secret-here
CHILD_JWT_TTL_HOURS=4
PARENT_JWT_TTL_DAYS=7

# Segurança
MODERATION_STRICT=true
BLOCKLIST_PATH=/app/safety/blocklist.txt
RATE_LIMIT_PER_MIN=60
MAX_MESSAGES_PER_SESSION=30
MAX_MESSAGES_PER_CHILD_PER_DAY=100

# Regional
TIMEZONE=America/Sao_Paulo

# API
API_BASE_URL=https://api.aprendizagem.app/v1
FRONTEND_ORIGIN=https://aprendizagem.app

# Logs
LOG_LEVEL=info
ENV=development

# Sentry (opcional)
SENTRY_DSN=https://your-dsn@sentry.io/project-id